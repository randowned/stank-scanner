; StankBot systemd unit — primary production deployment.
;
; Root install:
;     sudo cp stankbot.service /etc/systemd/system/
;     sudo systemctl daemon-reload
;     sudo systemctl enable --now stankbot
;
; User-level install (cPanel / shared hosts without root):
;     mkdir -p ~/.config/systemd/user
;     cp stankbot.service ~/.config/systemd/user/
;     loginctl enable-linger "$USER"
;     systemctl --user daemon-reload
;     systemctl --user enable --now stankbot
;
; Override ``User=``, ``WorkingDirectory=``, and ``EnvironmentFile=`` paths
; to match your host.

[Unit]
Description=StankBot — Discord application for the Maphra community
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=stankbot
WorkingDirectory=/opt/stankbot
EnvironmentFile=/etc/stankbot/stankbot.env
# Run pending Alembic migrations before the bot starts. systemd fails
# the unit if this exits non-zero, matching the Docker entrypoint.
ExecStartPre=/opt/stankbot/.venv/bin/alembic upgrade head
ExecStart=/opt/stankbot/.venv/bin/python -m stankbot
Restart=on-failure
RestartSec=5s
# Graceful shutdown: ``__main__`` catches SIGTERM and drains the
# scheduler + Discord gateway + DB engine. Give it room to finish the
# gateway close handshake before systemd escalates to SIGKILL.
KillSignal=SIGTERM
TimeoutStopSec=30s
SyslogIdentifier=stankbot
# Light hardening — tighten further once the host is locked down.
NoNewPrivileges=true
ProtectSystem=full
ProtectHome=true
PrivateTmp=true
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
